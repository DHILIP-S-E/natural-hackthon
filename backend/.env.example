# AURA â€” Environment Configuration
# Copy this to .env and fill in your values
# â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•



# â”€â”€ JWT â”€â”€
JWT_SECRET_KEY=your-jwt-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# â”€â”€ Storage â”€â”€
STORAGE_BACKEND=firebase

# Firebase Storage (used when STORAGE_BACKEND=firebase)
# Download service account JSON from Firebase Console â†’ Project Settings â†’ Service Accounts
FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com

# MinIO (used when STORAGE_BACKEND=minio)
STORAGE_ENDPOINT=your-server-ip:9000
STORAGE_ACCESS_KEY=your-minio-access-key
STORAGE_SECRET_KEY=your-minio-secret-key
STORAGE_BUCKET=aura-uploads
STORAGE_USE_SSL=false

# â”€â”€ Redis â”€â”€
REDIS_URL=redis://localhost:6379/0

# â”€â”€ OpenAI (for AI agents) â”€â”€
OPENAI_API_KEY=sk-xxx

# â”€â”€ OpenWeatherMap (for climate agents) â”€â”€
OPENWEATHER_API_KEY=

# â”€â”€ SendGrid (email notifications) â”€â”€
SENDGRID_API_KEY=

# â”€â”€ Twilio (WhatsApp notifications) â”€â”€
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# â”€â”€ App â”€â”€
APP_NAME=AURA
APP_ENV=development
CORS_ORIGINS=http://localhost:5173
